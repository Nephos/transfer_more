<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= ENV.fetch("TRANSFER_MORE_TITLE", "File upload") %></title>
  <link rel="shortcut icon" href="/images/favicon.ico" type="image/x-icon">
  <style>
    :root {
      --primary: #4f46e5;
      --muted: #6b7280;
      --success: #065f46;
      --radius: 12px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: #f8f9fa;
      color: #1f2937;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    main {
      width: 100%;
      max-width: 720px;
      padding: 2rem 1rem;
      flex: 1;
    }

    h1 {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .card {
      background: #fff;
      border-radius: var(--radius);
      box-shadow: 0 1px 3px rgba(0,0,0,.08);
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .alert-success {
      background: #ecfdf5;
      border: 1px solid #6ee7b7;
      color: var(--success);
      border-radius: var(--radius);
      padding: 1rem 1.25rem;
      margin-bottom: 1.5rem;
      word-break: break-all;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .alert-success a {
      color: inherit;
      font-weight: 600;
      flex: 1;
      min-width: 0;
    }

    .copy-btn {
      padding: 0.35rem 0.65rem;
      font-size: 0.8rem;
      background: var(--success);
      color: #fff;
      border: none;
      border-radius: 6px;
      cursor: pointer;
    }

    .copy-btn:hover { opacity: 0.85; }

    .curl-hint {
      background: #1e293b;
      color: #e2e8f0;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-family: "SFMono-Regular", Consolas, monospace;
      font-size: 0.8rem;
      overflow-x: auto;
      margin-bottom: 1.5rem;
      line-height: 1.5;
    }

    .dropzone-wrap {
      position: relative;
      border: 2px dashed #a5b4fc;
      border-radius: var(--radius);
      background: #eef2ff;
      transition: background 0.2s, border-color 0.2s;
    }

    .dropzone-wrap:hover {
      background: #c7d2fe;
      border-color: var(--primary);
    }

    .dropzone-wrap::before {
      content: "\1F4E5";
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 3rem;
      opacity: 0.5;
      pointer-events: none;
    }

    .dropzone {
      display: block;
      width: 100%;
      height: 300px;
      border: none;
      background: transparent;
      cursor: pointer;
      color: var(--muted);
    }

    .btn {
      display: block;
      width: 100%;
      padding: 0.75rem;
      margin-top: 1rem;
      font-size: 1rem;
      font-weight: 600;
      text-align: center;
      color: #fff;
      background: var(--primary);
      border: none;
      border-radius: 8px;
      cursor: pointer;
    }

    .btn:hover { background: #4338ca; }

    footer {
      width: 100%;
      max-width: 720px;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
      padding: 1rem;
      font-size: 0.8rem;
      color: var(--muted);
    }

    footer a { color: var(--primary); text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    @media (min-width: 768px) {
      main { max-width: 800px; padding: 3rem 2rem; }
      h1 { font-size: 2rem; }
      .card { padding: 2rem; }
      .dropzone { height: 350px; }
      .dropzone-wrap::before { font-size: 3.5rem; }
      footer { max-width: 800px; padding: 1rem 2rem; }
    }

    @media (min-width: 1200px) {
      main { max-width: 960px; padding: 4rem 2rem; }
      h1 { font-size: 2.25rem; margin-bottom: 2rem; }
      .card { padding: 2.5rem; }
      .dropzone { height: 400px; }
      .dropzone-wrap::before { font-size: 4rem; }
      footer { max-width: 960px; padding: 1.5rem 2rem; }
    }
  </style>
</head>

<body>
  <main>
    <h1><%= ENV.fetch("TRANSFER_MORE_TITLE", "File upload") %></h1>

    <% if !file_url.empty? %>
      <div class="alert-success">
        Upload url: <a href="<%= HTML.escape(file_url) %>"><%= HTML.escape(file_url) %></a>
        <button class="copy-btn" onclick="navigator.clipboard.writeText(this.previousElementSibling.href).then(function(){event.target.textContent='Copied!'})">
          Copy
        </button>
      </div>
    <% end %>

    <div class="curl-hint">
      curl --progress-bar --upload-file file.ext <%= TransferMore.base_url(env) %>/file.ext
    </div>

    <div class="card">
      <form method="POST" action="/" enctype="multipart/form-data">
        <div class="dropzone-wrap">
          <input class="dropzone" name="file" id="file" type="file" required></input>
        </div>
        <button type="submit" class="btn">Upload</button>
      </form>
    </div>
  </main>

  <footer>
    <span>
      <%= ENV.fetch("TRANSFER_MORE_FOOTER", "built by <a href=\"https://git.sceptique.eu/Sceptique\">Sceptique</a>, powered with <a href=\"http://kemalcr.com/\">kemal</a>") %>
    </span>
    <span>
      <a href="https://git.sceptique.eu/Sceptique/transfer_more">Fork or patch me</a>
    </span>
  </footer>

</body>
</html>
